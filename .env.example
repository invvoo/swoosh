# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER expose to the browser; used only in server-side API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Publishable key (safe to expose to the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Secret key — server-side only
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# From address used for all outbound emails
FROM_EMAIL=no-reply@latranslation.com

# ─── Anthropic (AI translation) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Token signing ───────────────────────────────────────────────────────────
# 32+ random bytes, base64 or hex encoded — used to sign quote and delivery JWTs
TOKEN_SECRET=replace-with-a-long-random-secret

# ─── Cron job protection ─────────────────────────────────────────────────────
# Sent as the x-cron-secret header by Vercel Cron; must match what you configure
CRON_SECRET=replace-with-a-long-random-secret

# ─── App URL ─────────────────────────────────────────────────────────────────
# Full URL of the deployed app (no trailing slash) — used to build email links
NEXT_PUBLIC_APP_URL=https://your-domain.com
